generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  waitlisted
  approved
  denied
}

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum PaymentStatus {
  pending
  paid
  refunded
  failed
}

enum ReservationStatus {
  reserved
  cancelled
  no_show
}

enum Course {
  appetizer
  entree
  dessert
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  firstName       String?       @map("first_name")
  lastName        String?       @map("last_name")
  phone           String?
  status          UserStatus    @default(waitlisted)
  profileComplete Boolean       @default(false) @map("profile_complete")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  reservations    Reservation[]

  @@map("users")
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Event {
  id                      String        @id @default(uuid())
  title                   String
  description             String        @db.Text
  date                    DateTime      @db.Timestamptz
  location                String
  pricePerSeat            Int           @map("price_per_seat")
  totalSeats              Int           @map("total_seats")
  menuImageUrl            String?       @map("menu_image_url")
  cancellationPolicyText  String        @db.Text @map("cancellation_policy_text")
  themeBgColor            String?       @map("theme_bg_color")
  themeAccentColor        String?       @map("theme_accent_color")
  themeHeaderImageUrl     String?       @map("theme_header_image_url")
  status                  EventStatus   @default(draft)
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")
  reservations            Reservation[]
  recipes                 Recipe[]

  @@map("events")
}

model Reservation {
  id                      String            @id @default(uuid())
  userId                  String            @map("user_id")
  eventId                 String            @map("event_id")
  partySize               Int               @map("party_size")
  totalAmount             Int               @map("total_amount")
  stripePaymentIntentId   String?           @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String?           @map("stripe_checkout_session_id")
  paymentStatus           PaymentStatus     @default(pending) @map("payment_status")
  reservationStatus       ReservationStatus @default(reserved) @map("reservation_status")
  confirmationNumber      String            @unique @map("confirmation_number")
  confirmationSentAt      DateTime?         @map("confirmation_sent_at")
  reminderSentAt          DateTime?         @map("reminder_sent_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  user                    User              @relation(fields: [userId], references: [id])
  event                   Event             @relation(fields: [eventId], references: [id])
  guests                  Guest[]

  @@map("reservations")
}

model Guest {
  id            String      @id @default(uuid())
  reservationId String      @map("reservation_id")
  name          String
  allergies     String?     @db.Text
  isPrimary     Boolean     @default(false) @map("is_primary")
  createdAt     DateTime    @default(now()) @map("created_at")
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@map("guests")
}

model Recipe {
  id           String            @id @default(uuid())
  eventId      String?           @map("event_id")
  name         String
  course       Course
  baseServings Int               @map("base_servings")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  event        Event?            @relation(fields: [eventId], references: [id])
  components   RecipeComponent[]
  steps        RecipeStep[]

  @@map("recipes")
}

model RecipeComponent {
  id          String             @id @default(uuid())
  recipeId    String             @map("recipe_id")
  label       String?
  sortOrder   Int                @map("sort_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  recipe      Recipe             @relation(fields: [recipeId], references: [id])
  ingredients RecipeIngredient[]

  @@map("recipe_components")
}

model RecipeIngredient {
  id          String          @id @default(uuid())
  componentId String          @map("component_id")
  name        String
  quantity    Decimal
  unit        String
  sortOrder   Int             @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  component   RecipeComponent @relation(fields: [componentId], references: [id])

  @@map("recipe_ingredients")
}

model RecipeStep {
  id          String   @id @default(uuid())
  recipeId    String   @map("recipe_id")
  stepNumber  Int      @map("step_number")
  instruction String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  recipe      Recipe   @relation(fields: [recipeId], references: [id])

  @@map("recipe_steps")
}
